# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
# Use a service role key no backend oficial.
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Storage bucket (criado manualmente no painel Supabase)
SUPABASE_BUCKET_ARQUIVOS_PROJETO=arquivos-projeto

# ─── Autenticação ────────────────────────────────────────────
# "true" em produção, "false" para dev local sem token
AUTH_OBRIGATORIO=true

# ─── Segurança da API ────────────────────────────────────────
# Docs abertas apenas em ambiente controlado
EXPOSE_API_DOCS=false
# Erros detalhados apenas em dev local
DEBUG_ERRORS=false
# Hosts aceitos pelo backend
ALLOWED_HOSTS=localhost,127.0.0.1,*.run.app,*.up.railway.app,*.vercel.app
# Origens CORS explícitas adicionais
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006

# ─── Desenvolvimento com proxy remoto ────────────────────────
# Use somente quando o backend local precisar espelhar a API remota
# DEV_PROXY_BACKEND_URL=https://geoadmin-pro-production.up.railway.app

# ─── Cloud Run / produção final ──────────────────────────────
# URL pública da API definitiva
# EXTERNAL_API_URL=https://SEU-SERVICO-xxxxx-uc.a.run.app

# ─── Railway (preenchido automaticamente no deploy) ──────────
# PORT=8000
