# URL publica definitiva da API.
# Obrigatoria para builds publicados no Vercel e no EAS.
EXPO_PUBLIC_API_BASE_URL=https://SEU-SERVICO.run.app

# Desenvolvimento local:
# - web usa http://127.0.0.1:8001 ou http://SEU-IP:8001 automaticamente
# - mobile usa o host do Expo Go quando disponivel
# - android emulator pode cair em http://10.0.2.2:8000
